{
  "name": "whamail-desktop",
  "version": "1.0.1",
  "description": "Whamail",
  "author": "Whamail",
  "homepage": "https://whamail.com",
  "repository": "github:krishna-dharsandia/whamail",
  "type": "module",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n next,api -c blue,green \"next dev --turbopack\" \"dotnet run --project ../MailBridge.API\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "electron:dev": "cross-env NODE_ENV=development concurrently -n next,electron -c blue,green \"next dev --turbopack\" \"node -e \\\"setTimeout(()=>process.exit(),3000)\\\" && electron .\"",
    "api:publish:win": "cd ../MailBridge.API && dotnet publish -c Release -r win-x64 --self-contained -o ../desktop/api/publish",
    "api:publish:mac-arm64": "cd ../MailBridge.API && dotnet publish -c Release -r osx-arm64 --self-contained -o ../desktop/api/publish",
    "api:publish:mac-x64": "cd ../MailBridge.API && dotnet publish -c Release -r osx-x64 --self-contained -o ../desktop/api/publish",
    "electron:build:next": "cross-env ELECTRON_BUILD=true next build",
    "icon-gen": "node scripts/generate-icons.mjs",
    "electron:build:main": "tsc -p electron/tsconfig.json",
    "electron:build:win": "npm run api:publish:win && npm run electron:build:next && npm run electron:build:main && electron-builder --win --x64",
    "electron:build:mac-arm64": "npm run api:publish:mac-arm64 && npm run electron:build:next && npm run electron:build:main && electron-builder --mac --arm64",
    "electron:build:mac-x64": "npm run api:publish:mac-x64 && npm run electron:build:next && npm run electron:build:main && electron-builder --mac --x64"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@base-ui/react": "^1.3.0",
    "@floating-ui/react": "^0.27.19",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.37.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-email-editor": "^1.7.11",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
