---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import { Card, CardHeader, CardContent, CardDescription } from "../components/ui/card";
import DownloadSection from "../components/DownloadSection";
---

<BaseLayout title="Whamail — Download">
  <main class="min-h-screen flex items-center justify-center p-4 sm:p-8">
    <Card class="w-full max-w-md">
      <CardHeader class="text-center pb-2">
        <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-xl bg-blue-600 shadow-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-7 w-7 text-white">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold tracking-tight">Whamail</h1>
        <CardDescription class="text-base">
          Email broadcast platform — desktop app
        </CardDescription>
      </CardHeader>
      <CardContent class="flex flex-col items-center gap-4 pt-0">
        <DownloadSection client:load />

        <p class="text-xs text-zinc-600 mt-2">
          <a
            href="https://github.com/krishna-dharsandia/whamail/releases"
            class="text-zinc-400 hover:text-zinc-300 transition-colors underline underline-offset-2"
          >
            View all releases on GitHub
          </a>
        </p>
      </CardContent>
    </Card>
  </main>
</BaseLayout>
